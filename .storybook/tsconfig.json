{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"ignoreDeprecations": "6.0"
	},

	"exclude": ["../**/*.spec.ts"],
	"include": [
		"../src/**/*.stories.ts",
		"../src/**/*.stories.js",
		"../src/**/*.stories.jsx",
		"../src/**/*.stories.tsx",
		"../src/**/*.stories.mdx",
		"*.js"
	]
}
