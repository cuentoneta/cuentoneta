{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"skipLibCheck": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": false,
		"noUncheckedSideEffectImports": false,
		"types": ["*"],
		"esModuleInterop": false,
		"ignoreDeprecations": "6.0"
	},
	"include": ["**/*.js"]
}
