{
	"version": 2,
	"public": true,
	"name": "cuentoneta",
	"buildCommand": "pnpm run build",
	"installCommand": "pnpm install --ignore-scripts && pnpm run config:production",
	"rewrites": [{ "source": "/(.*)", "destination": "/api" }],
	"functions": {
		"api/index.js": {
			"includeFiles": "dist/cuentoneta/browser/**"
		}
	}
}
